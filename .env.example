# Copy to .env and adjust. All variables are optional; defaults in parentheses.

# Port the Kestrel server listens on, localhost only (5000).
# Ignored when ASPNETCORE_URLS is set (e.g. inside Docker).
APP_PORT=5000

# Path to the SQLite database file (data/finance.db, relative to the working dir).
DB_PATH=data/finance.db

# Directory with the static frontend files (./public next to the working dir,
# falling back to the app base directory).
PUBLIC_DIR=public

# Seed an admin account at startup. If either is missing, no account is seeded.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
